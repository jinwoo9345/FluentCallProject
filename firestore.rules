rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 포인트 이체 시 상대방의 credits만 수정 가능하도록 제한하는 헬퍼
    function onlyCreditsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits']);
    }

    // 유저 정보
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // 본인은 전체 수정 가능, 타인은 credits 필드만 수정 가능 (포인트 선물용)
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || isAdmin()
        || onlyCreditsChanged()
      );
      allow delete: if isAdmin();
    }

    // 추천 코드 인덱스 (비로그인 상태에서도 코드 유효성 검증 가능)
    // 각 문서는 `{ userId, createdAt }` 형태의 최소 정보만 보관 (민감 정보 없음)
    match /referral_codes/{code} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // 포인트 이체 내역
    match /point_transfers/{transferId} {
      allow create: if isSignedIn()
        && request.resource.data.fromId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.fromId == request.auth.uid
        || resource.data.toId == request.auth.uid
        || isAdmin()
      );
    }

    // 튜터 목록
    match /tutors/{tutorId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // admin은 전체 편집 가능, 승인된 강사 본인은 자신의 tutor 문서를 수정 가능
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == tutorId);
    }

    // 수업 세션
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.tutorId == request.auth.uid
        || isAdmin()
      );
      allow list: if isAdmin();
      allow write: if isSignedIn();
    }

    // 상담 신청: 생성은 누구나 가능, 로그인 유저가 본인의 상담 업데이트 가능 (카카오 로그인 후 userId 링크용)
    match /consultations/{consultationId} {
      allow create: if true;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        || (isSignedIn() && (
          resource.data.userId == request.auth.uid
          || (resource.data.userId == null && request.resource.data.userId == request.auth.uid)
        ));
      allow delete: if isAdmin();
    }

    // 강사 신청
    match /tutor_applications/{appId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // 전역 앱 설정 (카카오 채널 URL 등 관리자가 수정하는 공개 설정)
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 결제 내역
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.tutorId == request.auth.uid
        || isAdmin()
      );
      allow list: if isAdmin()
        || (isSignedIn() && resource.data.tutorId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
    }
  }
}
