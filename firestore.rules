rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 타인의 credits 필드만 증가시키는 경우 (포인트 선물 수신자 업데이트)
    function validCreditIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits'])
        && request.resource.data.credits is int
        && resource.data.credits is int
        && request.resource.data.credits > resource.data.credits
        && (request.resource.data.credits - resource.data.credits) <= 100000;
    }

    // 본인이 자신의 credits만 감소시키는 경우 (포인트 선물 송신자 자기 자신 업데이트)
    function ownCreditsDecrementOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits'])
        && request.resource.data.credits is int
        && request.resource.data.credits >= 0
        && request.resource.data.credits < resource.data.credits;
    }

    // 유저 정보
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if isSignedIn() && request.auth.uid == userId;

      // 본인: 프로필 필드만 변경 가능 (credits 직접 수정 금지, 단 decrement은 허용 = 포인트 선물용)
      // 타인: credits 증가만 허용 (최대 10만P/회) - 포인트 선물 수신용
      // 관리자: 전체 허용
      allow update: if isSignedIn() && (
        isAdmin()
        || (request.auth.uid == userId && (
          !('credits' in request.resource.data.diff(resource.data).affectedKeys())
          || ownCreditsDecrementOnly()
        ))
        || validCreditIncrement()
      );
      allow delete: if isAdmin();
    }

    // 추천 코드 인덱스
    // 코드 포맷 강제 + 덮어쓰기 방지 + 본인 uid 검증
    match /referral_codes/{code} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && !exists(/databases/$(database)/documents/referral_codes/$(code))
        && code.size() >= 4 && code.size() <= 16
        && code.matches('^[A-Z0-9]+$');
      allow delete: if isAdmin();
    }

    // 포인트 이체 내역
    // fromName은 실제 송신자 이름과 일치해야 (피싱 방지), amount는 양의 정수
    match /point_transfers/{transferId} {
      allow create: if isSignedIn()
        && request.resource.data.fromId == request.auth.uid
        && request.resource.data.amount is int
        && request.resource.data.amount > 0;
      allow read: if isSignedIn() && (
        resource.data.fromId == request.auth.uid
        || resource.data.toId == request.auth.uid
        || isAdmin()
      );
    }

    // 튜터 목록
    match /tutors/{tutorId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == tutorId);
    }

    // 수업 세션 - 관리자만 쓰기 가능, 본인/튜터/관리자만 읽기
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.tutorId == request.auth.uid
        || isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }

    // 상담 신청 - 비로그인 create 허용
    // 미할당 상담(userId==null)만 로그인 사용자가 자신에게 연결 가능 (consultationId는
    // Firestore 자동 ID 20자라 모르는 유저가 claim 시도 불가). 다른 필드 변경은 관리자만.
    match /consultations/{consultationId} {
      allow create: if true;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.userId == null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']));
      allow delete: if isAdmin();
    }

    // 강사 신청
    match /tutor_applications/{appId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // 전역 앱 설정
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 플랫폼 후기 - rating은 1~5 정수만 허용
    match /platform_reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Q&A 게시판
    match /qna_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn()
          && resource.data.userId == request.auth.uid;
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // 정보 게시판
    match /info_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn()
          && resource.data.userId == request.auth.uid;
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // 튜터별 리뷰 - rating 1~5 정수만 허용
    match /tutor_reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 결제 내역
    // create: 본인 결제 생성 시 status는 pending 고정, amount는 양의 정수
    // update: 관리자만 가능 (status/amount/referralRewarded 등 금전 관련 필드 보호)
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.tutorId == request.auth.uid
        || isAdmin()
      );
      allow list: if isAdmin()
        || (isSignedIn() && resource.data.tutorId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.referralRewarded == false;
      allow update: if isAdmin();
    }
  }
}
