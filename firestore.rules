rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유저 정보: 본인 것만 읽기 가능, 수정은 인증된 유저만 (트랜잭션 허용)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // 포인트 이체 등을 위해 본인 문서는 수정 가능, 타인 문서는 특정 필드(credits)만 업데이트하도록 나중에 더 강화 가능
      allow write: if request.auth != null; 
    }
    
    // 포인트 이체 내역: 본인이 관련된 내역만 조회 가능, 생성은 인증된 유저만
    match /point_transfers/{transferId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }
    
    // 튜터 목록: 누구나 읽기 가능 (탐색용)
    match /tutors/{tutorId} {
      allow read: if true;
      allow write: if false; // 강사 등록은 관리자만 (추후 확장 가능)
    }
    
    // 수업 세션: 본인이 참여한 수업만 조회 가능
    match /sessions/{sessionId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.tutorId == request.auth.uid);
      allow write: if request.auth != null;
    }
    
    // 상담 신청: 생성은 누구나 가능 (비로그인 상담 허용), 읽기는 본인만 가능
    match /consultations/{consultationId} {
      allow create: if true;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // 결제 내역: 본인 것만 조회 가능
    match /payments/{paymentId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }
  }
}
