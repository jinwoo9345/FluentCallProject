{
  "entities": {
    "User": {
      "title": "User",
      "description": "플랫폼 사용자 정보 (수강생 또는 강사)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "사용자 이름" },
        "email": { "type": "string", "format": "email", "description": "이메일 주소" },
        "role": { "type": "string", "enum": ["student", "tutor"], "description": "사용자 역할" },
        "credits": { "type": "number", "description": "보유 크레딧 (수강생 전용)" },
        "avatar": { "type": "string", "description": "프로필 이미지 URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "가입 일시" },
        "referralCode": { "type": "string", "description": "자신의 추천인 코드" },
        "referredBy": { "type": "string", "description": "가입 시 입력한 추천인 코드" },
        "discountBalance": { "type": "number", "description": "추천으로 쌓인 할인 금액" }
      },
      "required": ["uid", "name", "email", "role", "referralCode"]
    },
    "Session": {
      "title": "Session",
      "description": "예약된 수업 세션",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "수강생 UID" },
        "tutorId": { "type": "string", "description": "강사 UID" },
        "startTime": { "type": "string", "format": "date-time", "description": "수업 시작 시간" },
        "duration": { "type": "number", "description": "수업 시간 (분)" },
        "status": { "type": "string", "enum": ["upcoming", "completed", "cancelled"], "description": "수업 상태" },
        "totalPrice": { "type": "number", "description": "총 결제 금액 (수수료 포함)" },
        "fee": { "type": "number", "description": "플랫폼 수수료" }
      },
      "required": ["studentId", "tutorId", "startTime", "status"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "무료 전화상담 신청 내역",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "신청자 이름" },
        "contactType": { "type": "string", "enum": ["kakao", "discord", "phone"], "description": "연락 수단" },
        "contactValue": { "type": "string", "description": "연락처 정보" },
        "availableTime": { "type": "string", "description": "상담 가능 시간" },
        "motivation": { "type": "string", "description": "신청 이유/동기/목적" },
        "notes": { "type": "string", "description": "기타 사항" },
        "createdAt": { "type": "string", "format": "date-time", "description": "신청 일시" }
      },
      "required": ["name", "contactType", "contactValue", "availableTime", "motivation", "createdAt"]
    },
    "Mail": {
      "title": "Mail",
      "description": "Trigger Email 확장을 위한 이메일 발송 큐",
      "type": "object",
      "properties": {
        "to": { "type": "string", "description": "수신자 이메일 주소" },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string", "description": "이메일 제목" },
            "html": { "type": "string", "description": "이메일 본문 (HTML)" }
          },
          "required": ["subject", "html"]
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "생성 일시" }
      },
      "required": ["to", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "사용자 프로필 컬렉션"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "수업 예약 정보 컬렉션"
    },
    "/consultations/{consultationId}": {
      "schema": "Consultation",
      "description": "무료 상담 신청 컬렉션"
    },
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "이메일 발송 대기열 컬렉션"
    }
  }
}
